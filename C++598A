#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int t; 
    if (cin >> t) {
        while (t--){
            long long n; 
            cin >> n;
            long long result = n * (n + 1) / 2;
            long long curr = 1;
            while (curr <= n){
                result -= (curr * 2);
                curr *= 2;
            }
            cout << result << "\n";
        }
    }
    return 0;
}
